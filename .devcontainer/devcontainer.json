{
  "name": "mqtt-qos-js",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-20-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
  },
  "forwardPorts": [1880, 1883],
  "portsAttributes": {
    "1880": {
      "label": "Node-RED UI",
      "onAutoForward": "openBrowser"
    },
    "1883": {
      "label": "Mosquitto MQTT"
    }
  },
  "postStartCommand": "docker compose -f labs/sprint3-nodered-hello/docker-compose.yml up -d --build"
}
